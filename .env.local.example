# ─────────────────────────────────────────────────────────────
# Blue Ocean Academy — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
#   cp .env.local.example .env.local
# ─────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────
# SANITY CMS
# Get these from: https://sanity.io/manage
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API Token (read/write — keep secret, never expose publicly)
# Generate at: https://sanity.io/manage → API → Tokens
SANITY_API_TOKEN=

# Sanity Webhook Secret (for on-demand revalidation)
SANITY_WEBHOOK_SECRET=


# ─────────────────────────────────────────────────────────────
# NEXT.JS
# ─────────────────────────────────────────────────────────────
# Base URL of the site (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ─────────────────────────────────────────────────────────────
# VERCEL (auto-injected in Vercel deployments — do not set manually)
# ─────────────────────────────────────────────────────────────
# VERCEL_URL=
# VERCEL_ENV=


# ─────────────────────────────────────────────────────────────
# ANALYTICS (optional — add when ready)
# ─────────────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
